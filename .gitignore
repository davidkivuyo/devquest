# ============================================
# DevQuest .gitignore
# ============================================

# --- Maintainer / private files ---
solutions/
*.solutions.md
SOLUTIONS.md

# --- Editor / IDE ---
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# --- OS junk ---
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
.Spotlight-V100
.Trashes

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Node (only relevant if tooling will be addedlater) ---
node_modules/
package-lock.json.bak
.pnpm-store/

# --- Build output (also future-proofing) ---
dist/
build/
out/
.cache/
.parcel-cache/

# --- Env / secrets (extra-paranoid) ---
.env
.env.local
.env.*.local
*.pem
*.key

# --- Misc ---
coverage/
.nyc_output/
.tmp/
tmp/
